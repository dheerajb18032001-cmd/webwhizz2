{
  "projects": {
    "default": "whizz-3fcf2"
  },
  "targets": {
    "whizz-3fcf2": {
      "hosting": [
        "whizz-platform"
      ]
    }
  },
  "hosting": [
    {
      "target": "whizz-platform",
      "public": "build",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-functions-debug.log"
      ],
      "runtime": "node24"
    }
  ]
}
