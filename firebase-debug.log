[debug] [2026-04-17T10:19:37.988Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/whizz-3fcf2/rulesets {"name":"projects/whizz-3fcf2/rulesets/0dccb79a-d98f-461d-9953-4b7b424ae0af","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    \r\n    // Approved admins collection - allow read for unauthenticated users during login\r\n    match /abc123/{docId} {\r\n      allow read: if true;  // Allow anyone to read admin emails during login\r\n      allow create, update, delete: if request.auth.token.admin == true;\r\n    }\r\n\r\n    // Users collection - own data or admins\r\n    match /users/{userId} {\r\n      allow read: if request.auth.uid == userId || request.auth.token.admin == true;\r\n      allow create: if request.auth.uid == userId;\r\n      allow update: if request.auth.uid == userId || request.auth.token.admin == true;\r\n      allow delete: if request.auth.token.admin == true;\r\n    }\r\n    \r\n    // Courses - Public read, admin/instructor write\r\n    match /courses/{courseId} {\r\n      allow read: if true;  // Anyone can read courses\r\n      allow create, update: if request.auth != null && (request.auth.token.admin == true || request.auth.token.instructor == true);\r\n      allow delete: if request.auth.token.admin == true;\r\n    }\r\n    \r\n    // Enrollments - Users can manage their own, admins can manage all\r\n    match /enrollments/{enrollmentId} {\r\n      allow read: if request.auth != null;\r\n      allow create: if request.auth != null;\r\n      allow update: if request.auth.uid == resource.data.studentId || request.auth.token.admin == true;\r\n      allow delete: if request.auth.token.admin == true;\r\n    }\r\n    \r\n    // Client messages - public create, admin read/delete\r\n    match /client/{clientId} {\r\n      allow create: if true;\r\n      allow read, update, delete: if request.auth.token.admin == true;\r\n    }\r\n\r\n    // Instructors collection\r\n    match /instructors/{instructorId} {\r\n      allow read: if true;\r\n      allow create, update: if request.auth.uid == instructorId || request.auth.token.admin == true;\r\n      allow delete: if request.auth.token.admin == true;\r\n    }\r\n\r\n    // Certificates\r\n    match /certificates/{certificateId} {\r\n      allow read: if request.auth != null;\r\n      allow create, update, delete: if request.auth.token.admin == true;\r\n    }\r\n\r\n    // Default deny all other documents\r\n    match /{document=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-04-17T10:19:38.247583Z","metadata":{"services":["cloud.firestore"]}}
