rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Approved admins collection - allow read for unauthenticated users during login
    match /abc123/{docId} {
      allow read: if true;  // Allow anyone to read admin emails during login
      allow create, update, delete: if request.auth.token.admin == true;
    }

    // Users collection - own data or admins
    match /users/{userId} {
      allow read: if request.auth.uid == userId || request.auth.token.admin == true;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || request.auth.token.admin == true;
      allow delete: if request.auth.token.admin == true;
    }
    
    // Courses - Public read, admin/instructor write
    match /courses/{courseId} {
      allow read: if true;  // Anyone can read courses
      allow create, update: if request.auth != null && (request.auth.token.admin == true || request.auth.token.instructor == true);
      allow delete: if request.auth.token.admin == true;
    }
    
    // Enrollments - Users can manage their own, admins can manage all
    match /enrollments/{enrollmentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.studentId || request.auth.token.admin == true;
      allow delete: if request.auth.token.admin == true;
    }
    
    // Client messages - public create, admin read/delete
    match /client/{clientId} {
      allow create: if true;
      allow read, update, delete: if request.auth.token.admin == true;
    }

    // Instructors collection
    match /instructors/{instructorId} {
      allow read: if true;
      allow create, update: if request.auth.uid == instructorId || request.auth.token.admin == true;
      allow delete: if request.auth.token.admin == true;
    }

    // Certificates
    match /certificates/{certificateId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth.token.admin == true;
    }

    // Default deny all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
